PDV_SERVER_TOKEN=pdv-agent-2024
PDV_SERVER_MONGO_URI=mongodb://192.168.1.20:27016

# Obrigatorias -- gere uma vez por instalacao, nunca reaproveite entre
# clientes/servidores, e nunca commite o valor real:
#   PDV_MASTER_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   PDV_SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
PDV_MASTER_KEY=
PDV_SECRET_KEY=

# So preencha se a rede interna deste cliente usa IPs fixos que nao podem ser
# alterados (replica set do Mongo) e exige um subnet router Tailscale com
# 4via6 (ver README, secao "Tailscale"). Deixe vazio se o Tailscale foi
# instalado direto em cada maquina (PDV/integrador) deste cliente.
PDV_TAILSCALE_SITE_ID=
