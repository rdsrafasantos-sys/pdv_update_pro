PDV_SERVER_TOKEN=pdv-agent-2024
PDV_SERVER_MONGO_URI=mongodb://192.168.1.20:27016

# Obrigatorias -- gere uma vez por instalacao, nunca reaproveite entre
# clientes/servidores, e nunca commite o valor real:
#   PDV_MASTER_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   PDV_SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
PDV_MASTER_KEY=
PDV_SECRET_KEY=

# So preencha se a rede interna deste cliente usa IPs fixos que nao podem ser
# alterados (replica set do Mongo) e exige um subnet router Tailscale com
# 4via6 (ver README, secao "Tailscale"). Deixe vazio se o Tailscale foi
# instalado direto em cada maquina (PDV/integrador) deste cliente.
PDV_TAILSCALE_SITE_ID=

# Automacao da tela de Instalacao (gerar auth key, atualizar ACL, aprovar
# rotas sem entrar no admin console). OAuth client em Settings > OAuth
# clients, escopos ACL + Auth Keys + Devices. Sem isso preenchido, a tela
# de Instalacao mostra os comandos pronto para copiar/colar manualmente
# em vez de rodar sozinha.
# Auth key reutilizavel para service managers -- gerada UMA VEZ em
# Settings > Keys (reusable, nao-efemera, tag:pdv-service-manager).
# Quando preenchida, o script e gerado instantaneamente sem chamar a API.
# Validade maxima 90 dias -- renove antes de expirar.
PDV_TAILSCALE_AUTH_KEY_SERVICE_MANAGER=

PDV_TAILSCALE_OAUTH_CLIENT_ID=
PDV_TAILSCALE_OAUTH_CLIENT_SECRET=
PDV_TAILSCALE_TAILNET=-
PDV_PAINEL_CALLBACK_URL=
